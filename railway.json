{
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "buildArgs": {
      "OPENCLAW_INSTALL_BROWSER": ""
    }
  },
  "deploy": {
    "startCommand": "node openclaw.mjs gateway --allow-unconfigured",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
